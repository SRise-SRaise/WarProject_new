<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.springboot.mapper.EduExperimentMapper">

    <resultMap id="BaseResultMap" type="com.springboot.model.entity.EduExperiment">
            <id property="id" column="experiment_id" />
            <result property="sortOrder" column="experiment_no" />
            <result property="name" column="experiment_name" />
            <result property="categoryId" column="experiment_type" />
            <result property="fileType" column="instruction_type" />
            <result property="requirement" column="experiment_requirement" />
            <result property="contentDesc" column="experiment_content" />
            <result property="publishStatus" column="state" />
    </resultMap>

    <sql id="Base_Column_List">
        experiment_id,experiment_no,experiment_name,experiment_type,instruction_type,
        experiment_requirement,experiment_content,state
    </sql>
</mapper>
