<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.springboot.mapper.ResScoreSummaryMapper">

    <resultMap id="BaseResultMap" type="com.springboot.model.entity.ResScoreSummary">
            <id property="id" column="score_id" />
            <result property="studentId" column="student_id" />
            <result property="experimentId" column="experiment_id" />
            <result property="totalScore" column="score" />
    </resultMap>

    <sql id="Base_Column_List">
        score_id,student_id,experiment_id,score
    </sql>
</mapper>
