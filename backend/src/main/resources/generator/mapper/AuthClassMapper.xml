<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.springboot.mapper.AuthClassMapper">

    <resultMap id="BaseResultMap" type="com.springboot.model.entity.user.AuthClass">
            <id property="classCode" column="class_code" />
            <result property="headmasterName" column="headmaster_name" />
            <result property="classStatus" column="class_status" />
            <result property="createdAt" column="created_at" />
            <result property="updatedAt" column="updated_at" />
